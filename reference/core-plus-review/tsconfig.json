{
  "compilerOptions": {
    "target":             "ES2022",
    "module":             "ESNext",
    "moduleResolution":   "node",
    "esModuleInterop":    true,
    "strict":             true,
    "skipLibCheck":       true,
    "noEmit":             true,
    "isolatedModules":    true,
    "resolveJsonModule":  true
  },
  "include": ["server.ts", "client.ts", "analyze-overrides.ts"]
}
