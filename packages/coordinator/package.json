{
  "name": "@chap/coordinator",
  "version": "0.2.2",
  "description": "CHAP Coordinator library: the protocol code as an importable module. Covers Core plus every profile.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".":           "./src/index.ts",
    "./canonical": "./src/canonical.ts",
    "./crypto":    "./src/crypto.ts",
    "./ids":       "./src/ids.ts",
    "./jsonrpc":   "./src/jsonrpc.ts",
    "./patch":     "./src/patch.ts",
    "./types":     "./src/types.ts"
  },
  "scripts": {
    "test":      "tsx --test tests/*.test.ts",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx":         "^4.7.0",
    "typescript":  "^5.3.0"
  },
  "private": true,
  "engines": { "node": ">=18" }
}
