{
  "name": "@chap/coordinator-a2a",
  "version": "0.2.7",
  "description": "A2A server adapter for the CHAP Coordinator. Exposes every CHAP method as an A2A AgentSkill.",
  "license": "Apache-2.0",
  "author": "Brightbeam AI <oss@brightbeam.ai>",
  "homepage": "https://github.com/BrightbeamAI/chap",
  "repository": {
    "type": "git",
    "url": "https://github.com/BrightbeamAI/chap.git",
    "directory": "packages/coordinator-a2a"
  },
  "bugs": {
    "url": "https://github.com/BrightbeamAI/chap/issues"
  },
  "keywords": [
    "chap",
    "a2a",
    "agent2agent",
    "agent",
    "skill",
    "orchestrator"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./card": {
      "types": "./dist/card.d.ts",
      "import": "./dist/card.js",
      "require": "./dist/card.cjs"
    },
    "./executor": {
      "types": "./dist/executor.d.ts",
      "import": "./dist/executor.js",
      "require": "./dist/executor.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@chap/coordinator": "^0.2.7",
    "@chap/coordinator-mcp": "^0.2.7"
  },
  "devDependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@chap/coordinator": "file:../coordinator",
    "@chap/coordinator-mcp": "file:../coordinator-mcp",
    "@types/node": "^20.11.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
